# Database - Neon PostgreSQL (ou use o Supabase PostgreSQL)
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-your-endpoint.c-x.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Supabase Storage
SUPABASE_URL="https://SEU_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="sua_anon_key_aqui"
SUPABASE_SERVICE_ROLE_KEY="sua_service_role_key_aqui"
SUPABASE_STORAGE_BUCKET="agmusic"

# Next.js
NODE_ENV="production"
NEXT_PUBLIC_SITE_URL="https://producoes.agmusic.cloud"

# Security - Generate random strings for production
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="https://producoes.agmusic.cloud"
